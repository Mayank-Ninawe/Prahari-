{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a Prahari user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "workStyle": { "type": "string" },
        "timezone": { "type": "string" },
        "demoModeEnabled": { "type": "boolean" },
        "notificationPreferences": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "fullName"]
    },
    "Task": {
      "title": "Task",
      "description": "Represents a tracked project/milestone task with computed risk indices",
      "type": "object",
      "properties": {
        "taskId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "estimatedMinutes": { "type": "integer" },
        "priority": { "type": "string" },
        "status": { "type": "string" },
        "riskScore": { "type": "integer" },
        "riskLevel": { "type": "string" },
        "riskReasonSummary": { "type": "string" },
        "selectedPlanId": { "type": "string" },
        "nextActionLabel": { "type": "string" },
        "source": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["taskId", "title"]
    },
    "RescuePlan": {
      "title": "RescuePlan",
      "description": "Represents a scope compressed plan generated by Gemini AI",
      "type": "object",
      "properties": {
        "planId": { "type": "string" },
        "planTitle": { "type": "string" },
        "planSummary": { "type": "string" },
        "steps": { "type": "array" },
        "totalEstimatedMinutes": { "type": "integer" },
        "firstActionLabel": { "type": "string" },
        "compressionMode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["planId", "planTitle"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "Root collection for user profiles"
    },
    "/users/{uid}/tasks/{taskId}": {
      "schema": "Task",
      "description": "User specific tasks"
    },
    "/users/{uid}/tasks/{taskId}/rescuePlans/{planId}": {
      "schema": "RescuePlan",
      "description": "AI-generated rescue plans for a given task"
    }
  }
}
